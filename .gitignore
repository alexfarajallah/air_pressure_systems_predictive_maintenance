# Ignore everything by default.
*

# Keep only the project folders intended for GitHub.
!README*.md
!requirements.txt
!.python-version
!runtime.txt
!data/
!data/**
data/processed/*.csv
!models/
!models/**
!notebooks/
!notebooks/**
!src/
!src/**
!tests/
!tests/**

# Always ignore local/generated files inside allowed folders.
__pycache__/
*.py[cod]
.ipynb_checkpoints/
tests/.tmp_db/

# Keep Git metadata rules readable if this file is updated later.
!.gitignore
